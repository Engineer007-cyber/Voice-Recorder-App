<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground"
    tools:context=".EditAudioActivity">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimaryContainer"
        app:layout_constraintTop_toTopOf="parent"
        app:title="Edit Recording"
        app:titleCentered="true"
        app:titleTextColor="?attr/colorOnPrimaryContainer" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardPreview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:strokeColor="?attr/colorOutlineVariant"
        app:strokeWidth="1dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_lock_silent_mode_off"
                app:tint="?attr/colorPrimary" />

            <TextView
                android:id="@+id/tvCurrentName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Recording Name"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textAlignment="center" />

            <TextView
                android:id="@+id/tvFilePath"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="/storage/emulated/0/..."
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                android:alpha="0.6"
                android:ellipsize="middle"
                android:singleLine="true" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tvActionsLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="28dp"
        android:layout_marginTop="24dp"
        android:text="Actions"
        android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
        android:textColor="?attr/colorPrimary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cardPreview" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnRename"
        style="@style/Widget.Material3.Button.TonalButton"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="8dp"
        android:text="Rename File"
        android:textAllCaps="false"
        app:icon="@android:drawable/ic_menu_edit"
        app:iconGravity="textStart"
        app:iconPadding="12dp"
        app:layout_constraintTop_toBottomOf="@id/tvActionsLabel" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnTrim"
        style="@style/Widget.Material3.Button.TonalButton"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="12dp"
        android:text="Trim Audio"
        android:textAllCaps="false"
        app:icon="@android:drawable/btn_star"
        app:iconPadding="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnRename" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDelete"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="12dp"
        android:text="Delete Permanently"
        android:textAllCaps="false"
        android:textColor="?attr/colorError"
        app:icon="@android:drawable/ic_menu_delete"
        app:iconGravity="textStart"
        app:iconPadding="12dp"
        app:iconTint="?attr/colorError"
        app:layout_constraintTop_toBottomOf="@id/btnTrim" />

</androidx.constraintlayout.widget.ConstraintLayout>